# Copy the relevant values into server/.env (see README).

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL — must match docker-compose.yml
DATABASE_URL="postgresql://cms:cms_password@localhost:5432/center_management?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
