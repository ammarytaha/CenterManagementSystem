# Copy the relevant values into server/.env (see README).

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL — must match docker-compose.yml (host port 5433 to avoid clashing
# with a local Postgres on 5432).
DATABASE_URL="postgresql://cms:cms_password@localhost:5433/center_management?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
